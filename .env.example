DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
# En az 32 karakter. Üret: openssl rand -base64 48
# ÜRETİMDE: dosyaya değil, gerçek ortam değişkeni/secret manager ile verilmeli.
JWT_SECRET=
# Groq (OpenAI-uyumlu API) — https://console.groq.com
GROQ_API_KEY=
# Opsiyonel: güncel model listesi https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile
# Opsiyonel: başka bir OpenAI-uyumlu sağlayıcıya yönlendirmek için
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Auth: hibrit token yapılandırması ---
# Access token: bellekte tutulur, Authorization header ile taşınır
ACCESS_TOKEN_TTL=15m
# Refresh token: HttpOnly cookie, /auth yoluna kapsanmış
REFRESH_TOKEN_TTL=168h
# Cookie: üretimde COOKIE_SECURE=true ZORUNLU (HTTPS)
COOKIE_SECURE=false
# strict | lax | none  — none seçilirse CSRF token'ı eklenmeli
COOKIE_SAMESITE=strict
COOKIE_DOMAIN=

# --- Rate limiting (dakikada istek) ---
# IP başına: /login, /register, /auth/refresh
AUTH_RATE_PER_MIN=10
# Kullanıcı başına: /chat (her istek gerçek para harcıyor)
CHAT_RATE_PER_MIN=20

# --- Veritabanı log seviyesi: silent | error | warn (varsayılan) | info ---
# info tüm SQL'i basar; hata ayıklarken faydalı, üretimde kapalı olmalı
DB_LOG_LEVEL=warn

# --- Bütçe dönemi saat dilimi ---
# Dönem yenilenme sınırı bu takvim gününe göre hesaplanır. Boş/geçersizse UTC.
# Konteynerler UTC çalıştığından üretimde AÇIKÇA ayarlanmalı; yoksa Türkiye'de
# dönem 3 saat erken döner (hata vermeden, sessizce yanlış).
APP_TIMEZONE=Europe/Istanbul
